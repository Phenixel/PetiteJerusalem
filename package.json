{
  "name": "petite-jerusalem",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "emulators": "node scripts/emulators.mjs",
    "dev:local": "run-p -l emulators dev",
    "build": "run-s type-check build-only prerender",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "prerender": "node scripts/prerender-seo.mjs",
    "indexnow": "node scripts/indexnow.mjs",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "verify": "npm run type-check && npm run lint && vitest run --passWithNoTests",
    "app:build": "run-s build app:prune cap:sync",
    "app:prune": "node scripts/prune-native-bundle.mjs",
    "cap:sync": "cap sync",
    "cap:android": "run-s app:build && cap open android",
    "cap:ios": "run-s app:build && cap open ios",
    "store:screenshots": "node scripts/store-screenshots.mjs"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor-firebase/messaging": "^8.3.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/file-transfer": "^2.0.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "^8.0.3",
    "@capacitor/text-zoom": "^8.0.1",
    "@tailwindcss/vite": "^4.1.17",
    "firebase": "^12.2.1",
    "vue": "^3.5.18",
    "vue-i18n": "^11.2.7",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@googleapis/androidpublisher": "^36.0.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.16.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/eslint-plugin": "^1.3.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "~10.3.0",
    "google-auth-library": "^10.9.0",
    "jiti": "^2.4.2",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "playwright": "^1.61.1",
    "prettier": "3.6.2",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.8.0",
    "vite": "^7.0.6",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.4"
  }
}
