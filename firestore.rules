rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fonctions utilitaires
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && request.auth.token.email in ['admin@phenixel.fr']
        && request.auth.token.email_verified == true;
    }

    function isSessionOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.personId;
    }

    // Ne permettre de modifier QUE le champ 'reservations'
    function onlyReservationsChanged() {
      let keys = request.resource.data.diff(resource.data).changedKeys();
      return keys.hasAll(['reservations']) && keys.size() == 1;
    }

    // Helper tailles de tableaux, compatible si 'reservations' absent dans la ressource
    function currentReservationsSize() {
      return resource.data.keys().hasAny(['reservations']) && resource.data.reservations is list
        ? resource.data.reservations.size()
        : 0;
    }

    // Ajout de réservations (taille +1 à +100) et aucune autre modif.
    // Autorisé sans authentification : les invités réservent avec leur nom
    // (email optionnel selon le réglage de la session).
    // Bornes pour empêcher un gonflement illimité du document.
    function isAppendReservationsOnly() {
      return onlyReservationsChanged() &&
             (request.resource.data.reservations is list) &&
             request.resource.data.reservations.size() >= currentReservationsSize() + 1 &&
             request.resource.data.reservations.size() <= currentReservationsSize() + 100 &&
             request.resource.data.reservations.size() <= 5000;
    }

    // Suppression d'UNE réservation (taille -1) et aucune autre modif.
    // Autorisé sans authentification : un invité doit pouvoir annuler sa
    // réservation. NB : la propriété fine par élément n'est pas vérifiable
    // dans les rules avec ce modèle (tableau embarqué) — voir la note du
    // README de PR ; une migration vers une sous-collection permettrait
    // de la faire respecter côté serveur.
    function isRemoveOneReservationOnly() {
      return onlyReservationsChanged() &&
             (request.resource.data.reservations is list) &&
             request.resource.data.reservations.size() == currentReservationsSize() - 1;
    }

    // Modification de réservations à taille constante (marquer « lu », etc.)
    function isUpdateReservationOnly() {
      return onlyReservationsChanged() &&
             (request.resource.data.reservations is list) &&
             request.resource.data.reservations.size() == currentReservationsSize();
    }

    // Sessions : lecture publique (le partage de lecture est ouvert à tous)
    match /sessions/{sessionId} {
      allow read: if true;
      // Création : utilisateur connecté, qui ne peut créer que SES sessions
      allow create: if isAuthenticated() && request.resource.data.personId == request.auth.uid;

      // Mise à jour : propriétaire/admin, ou opérations bornées sur le seul
      // champ 'reservations' (réservation, annulation, statut de lecture —
      // ouvertes aux invités non connectés, voir plus haut)
      allow update: if isSessionOwner() || isAdmin() || isAppendReservationsOnly() || isRemoveOneReservationOnly() || isUpdateReservationOnly();

      // Suppression : propriétaire ou admin uniquement
      allow delete: if isSessionOwner() || isAdmin();
    }

    // Compteur de vues d'un chiour : ouvert aux visiteurs non connectés,
    // mais borné au strict incrément (+1 sur le seul champ `views`, chiour
    // publié uniquement). Même esprit que les réservations des sessions.
    function currentViews() {
      return resource.data.keys().hasAny(['views']) && resource.data.views is int
        ? resource.data.views
        : 0;
    }

    function isViewsIncrementOnly() {
      // affectedKeys (et non changedKeys) : à la toute première vue, le champ
      // `views` est AJOUTÉ au document, pas modifié.
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasAll(['views']) && keys.size() == 1
        && resource.data.published == true
        && request.resource.data.views is int
        && request.resource.data.views == currentViews() + 1;
    }

    // Chiourim (catalogue audio) : lecture publique, écriture réservée aux admins.
    // Les auteurs invités écrivent via les Cloud Functions studio* (admin SDK),
    // qui vérifient leur token et n'autorisent que leurs brouillons.
    match /chiourim/{chiourId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isViewsIncrementOnly();
    }

    // Auteurs de chiourim : lecture publique (pages auteur), écriture admin
    match /auteurs/{auteurId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Séries de chiourim : lecture publique, écriture admin. La création par
    // un auteur invité passe par la Cloud Function studioSubmitChiour
    // (firebase-admin, non soumis à ces règles).
    match /series/{serieId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Tokens du studio auteurs : le doc ID EST le secret (32 octets aléatoires).
    // `get` ouvert : connaître le token, c'est être l'auteur — il n'est pas
    // devinable et le doc ne contient rien de sensible. `list` interdit aux
    // non-admins : aucune énumération possible.
    match /studioTokens/{token} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Préférences utilisateur (thème, lectures quotidiennes…) : privées
    match /userPreferences/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create, update: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.size() <= 12
        && (!('theme' in request.resource.data) || (request.resource.data.theme is string && request.resource.data.theme.size() <= 20))
        && (!('fontLatin' in request.resource.data) || (request.resource.data.fontLatin is string && request.resource.data.fontLatin.size() <= 20))
        && (!('fontHebrew' in request.resource.data) || (request.resource.data.fontHebrew is string && request.resource.data.fontHebrew.size() <= 20))
        && (!('dailyReadingIds' in request.resource.data) || (request.resource.data.dailyReadingIds is list && request.resource.data.dailyReadingIds.size() <= 200))
        && (!('dailyReadingProgress' in request.resource.data) || request.resource.data.dailyReadingProgress is map)
        // Notifications push (app native) : tokens FCM des appareils, rappel
        // on/off, langue des notifications. 20 tokens max — les tokens morts
        // sont purgés par la Cloud Function dailyReadingReminder quand un
        // envoi échoue.
        && (!('fcmTokens' in request.resource.data) || (request.resource.data.fcmTokens is list && request.resource.data.fcmTokens.size() <= 20))
        && (!('pushReminderEnabled' in request.resource.data) || request.resource.data.pushReminderEnabled is bool)
        && (!('pushReminderHour' in request.resource.data) || (request.resource.data.pushReminderHour is int && request.resource.data.pushReminderHour >= 0 && request.resource.data.pushReminderHour <= 23))
        && (!('pushLocale' in request.resource.data) || (request.resource.data.pushLocale is string && request.resource.data.pushLocale.size() <= 5))
        // Chiourim déjà vus (slugs) : marqueur « Vu » des utilisateurs connectés.
        && (!('viewedChiourim' in request.resource.data) || (request.resource.data.viewedChiourim is list && request.resource.data.viewedChiourim.size() <= 1000));
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Toute autre collection : accès refusé par défaut (pas de règle catch-all).
  }
}
