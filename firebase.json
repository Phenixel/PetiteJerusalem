{
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
    }
  ],
  "hosting": {
    "public": "dist",
    "cleanUrls": true,
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "redirects": [
      { "source": "/etude", "type": 301, "destination": "/bibliotheque" },
      { "source": "/etude/**", "type": 301, "destination": "/bibliotheque/:splat" }
    ],
    "rewrites": [
      {
        "source": "/og/session/**",
        "function": "ogImage"
      },
      {
        "source": "/share-reading/session/**",
        "function": "socialPreview"
      },
      {
        "source": "/chiourim/**",
        "function": "socialPreview"
      },
      {
        "source": "**",
        "destination": "/app.html"
      }
    ]
  },
  "emulators": {
    "auth": {
      "port": 9199
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9299
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}
